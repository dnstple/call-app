# Copy this file to .env and fill in your Supabase project values.
# Find them in your Supabase dashboard under Project Settings → API.
# The anon key is safe for the browser; NEVER put the service_role key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Data source: "mock" (default — fully local prototype, no auth required)
# or "supabase" (real authentication + RLS; feature data local until 2C).
# Can also be switched at runtime via Settings → Prototype tools → Data mode.
VITE_DATA_SOURCE=mock

# The URL this app runs at — used for email confirmation and password-reset
# redirects. Change for deployed environments.
VITE_APP_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# LiveKit (Stage 2F1 / Stage 3A — secure audio calling)
#
# SERVER-ONLY. These values are NOT read by the frontend and must NEVER become
# VITE_ variables: the API key and secret belong ONLY in Supabase Edge Function
# secrets. The browser receives a short-lived token AND the WebSocket URL from
# the livekit-token function response — so no public VITE_LIVEKIT_URL is needed
# (prefer the token endpoint over exposing the URL separately).
#
# LiveKit Cloud is the default MVP target, but LIVEKIT_URL is fully
# configurable, so self-hosting remains possible later. Do NOT provision a
# LiveKit Cloud project during Stage 3A.
#
#   supabase secrets set LIVEKIT_URL=wss://your-project.livekit.cloud
#   supabase secrets set LIVEKIT_API_KEY=your-livekit-api-key
#   supabase secrets set LIVEKIT_API_SECRET=your-livekit-api-secret
#   supabase functions deploy livekit-token
#   supabase functions deploy livekit-webhook --no-verify-jwt
#
# The placeholders below exist only as documentation. Do not commit real
# values anywhere in this repository.
# ---------------------------------------------------------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Optional and usually UNNECESSARY: the token endpoint already returns the ws
# URL. Only set this if a build genuinely needs the URL before requesting a
# token. It is a public URL only — never the key or secret.
# VITE_LIVEKIT_URL=
