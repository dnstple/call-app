# Copy this file to .env and fill in your Supabase project values.
# Find them in your Supabase dashboard under Project Settings → API.
# The anon key is safe for the browser; NEVER put the service_role key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Data source: "mock" (default — fully local prototype, no auth required)
# or "supabase" (real authentication + RLS; feature data local until 2C).
# Can also be switched at runtime via Settings → Prototype tools → Data mode.
VITE_DATA_SOURCE=mock

# The URL this app runs at — used for email confirmation and password-reset
# redirects. Change for deployed environments.
VITE_APP_URL=http://localhost:5173
